---
import { getImage } from 'astro:assets'
import { SEO } from 'astro-seo'

import faviconSrc from '~/assets/favicon.webp'

interface Props {
  title: string
  description: string
  image?: string | undefined
  locale: string
}

const { title, description, image, locale } = Astro.props

async function favicon(size: number, format: 'webp' | 'png') {
  return await getImage({
    src: faviconSrc,
    width: size,
    height: size,
    format,
  })
}

const websiteImage = image
  ? new URL(image, Astro.url).toString()
  : faviconSrc.src
---

<meta charset="utf-8" />
<meta name="viewport" content="width=device-width, initial-scale=1, viewport-fit=cover" />
<meta name="generator" content={Astro.generator} />
<SEO
  title={title}
  description={description}
  openGraph={{
    basic: {
      title,
      type: "article",
      image: websiteImage,
      url: Astro.url.toString(),
    },
    optional: {
      locale
    }
  }}
  twitter={{
    title,
    description
  }}
  extend={{
    link: [
      { rel: "icon", type: "image/png", href: (await favicon(32, "png")).src },
      { rel: "apple-touch-icon", href: (await favicon(180, "png")).src },
    ],
  }}
/>
